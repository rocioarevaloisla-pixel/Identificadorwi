<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Identificador.Views.HomePage"
             Title="Inicio"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="Auto,*">
        <BoxView HeightRequest="4"
                 Color="{StaticResource Primary}"
                 HorizontalOptions="Fill" />

        <VerticalStackLayout Grid.Row="1"
                             VerticalOptions="Center"
                             Spacing="20" Padding="30">
            <Label Text="🌱"
                   FontSize="40"
                   HorizontalOptions="Center" />

            <Label Text="Identificador"
                   FontSize="32" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center" />

            <Label x:Name="BienvenidoLabel"
                   Text="Bienvenido"
                   FontSize="22"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Tertiary}" />

            <BoxView HeightRequest="1"
                     Color="{StaticResource Gray200}"
                     Margin="40,0"
                     HorizontalOptions="Fill" />

            <Label Text="Presiona el botón para comenzar a identificar plantas"
                   FontSize="16"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Button x:Name="IdentificarBtn" Text="Identificar Planta"
                    Clicked="OnIdentificarPlanta"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    FontSize="18"
                    CornerRadius="12"
                    Padding="20,14"
                    HorizontalOptions="Fill"
                    Margin="0,10,0,0" />
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False" IsVisible="False"
                               Color="{StaticResource Primary}"
                               HeightRequest="40"
                               VerticalOptions="Center" />

            <Border x:Name="ResultadoFrame"
                    IsVisible="False"
                    BackgroundColor="{StaticResource White}"
                    Stroke="{StaticResource Primary}"
                    StrokeShape="RoundRectangle 12"
                    Padding="16"
                    HorizontalOptions="Fill"
                    Margin="0,10,0,0">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="🌿"
                           FontSize="28"
                           HorizontalOptions="Center" />
                    <Label x:Name="ResultadoNombreCientifico"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                    <Label x:Name="ResultadoNombreComun"
                           FontSize="15"
                           TextColor="{StaticResource Tertiary}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                    <BoxView HeightRequest="1"
                             Color="{StaticResource Gray200}"
                             Margin="20,4"
                             HorizontalOptions="Fill" />
                    <Label x:Name="ResultadoScore"
                           FontSize="13"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Gray500}" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Cerrar sesión"
                    Clicked="OnCerrarSesion"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    BorderColor="{StaticResource Primary}"
                    BorderWidth="1"
                    CornerRadius="12"
                    Padding="20,14"
                    HorizontalOptions="Fill" />

            <Label Text="Sobre nosotros"
                   FontSize="14"
                   TextColor="{StaticResource Secondary}"
                   HorizontalOptions="Center"
                   TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSobreNosotros" />
                </Label.GestureRecognizers>
            </Label>
        </VerticalStackLayout>

        <Border x:Name="SuccessOverlay"
                Grid.RowSpan="2"
                IsVisible="False"
                BackgroundColor="#80000000"
                VerticalOptions="Fill" HorizontalOptions="Fill">
            <Border BackgroundColor="White"
                    Stroke="{StaticResource Primary}"
                    StrokeShape="RoundRectangle 16"
                    Padding="28"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="280">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Label Text="🌿"
                           FontSize="36"
                           HorizontalOptions="Center" />
                    <Label Text="Planta identificada"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center" />
                    <Button Text="OK"
                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                            CornerRadius="10" Padding="16,8"
                            FontSize="15" FontAttributes="Bold"
                            HorizontalOptions="Fill"
                            Clicked="OnCerrarSuccess" />
                </VerticalStackLayout>
            </Border>
        </Border>
    </Grid>

</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Identificador.Views.HomePage"
             Title="Inicio"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <VerticalStackLayout VerticalOptions="Center" Spacing="20" Padding="30">
        <Label Text="Identificador"
               FontSize="32" FontAttributes="Bold"
               TextColor="{StaticResource Primary}"
               HorizontalOptions="Center" />

        <Label x:Name="BienvenidoLabel"
               Text="Bienvenido"
               FontSize="24"
               HorizontalOptions="Center"
               TextColor="{StaticResource Tertiary}" />

        <Label Text="Presiona el botón para comenzar a identificar plantas"
               FontSize="16"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               Margin="0,20,0,0" />

        <Button Text="Identificar Planta"
                BackgroundColor="{StaticResource Primary}" TextColor="White"
                FontSize="18"
                CornerRadius="12"
                Padding="20,14"
                HorizontalOptions="Fill"
                Margin="0,20,0,0" />

        <Button Text="Cerrar sesión"
                BackgroundColor="Transparent"
                TextColor="{StaticResource Primary}"
                BorderColor="{StaticResource Primary}"
                BorderWidth="1"
                CornerRadius="12"
                Padding="20,14"
                HorizontalOptions="Fill" />
    </VerticalStackLayout>

</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Identificador.Views.HomePage"
             Title="Inicio"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="Auto,*">
        <BoxView HeightRequest="4"
                 Color="{StaticResource Primary}"
                 HorizontalOptions="Fill" />

        <VerticalStackLayout Grid.Row="1"
                             VerticalOptions="Center"
                             Spacing="20" Padding="30">
            <Label Text="🌱"
                   FontSize="40"
                   HorizontalOptions="Center" />

            <Label Text="Identificador"
                   FontSize="32" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center" />

            <Label x:Name="BienvenidoLabel"
                   Text="Bienvenido"
                   FontSize="22"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Tertiary}" />

            <BoxView HeightRequest="1"
                     Color="{StaticResource Gray200}"
                     Margin="40,0"
                     HorizontalOptions="Fill" />

            <Label Text="Presiona el botón para comenzar a identificar plantas"
                   FontSize="16"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Button Text="Identificar Planta"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    FontSize="18"
                    CornerRadius="12"
                    Padding="20,14"
                    HorizontalOptions="Fill"
                    Margin="0,10,0,0" />

            <Button Text="Cerrar sesión"
                    Clicked="OnCerrarSesion"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    BorderColor="{StaticResource Primary}"
                    BorderWidth="1"
                    CornerRadius="12"
                    Padding="20,14"
                    HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>

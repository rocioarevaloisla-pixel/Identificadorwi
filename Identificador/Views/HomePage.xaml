<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Identificador.Views.HomePage"
             Title="Inicio"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="Auto,*">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource PrimaryDark}" Offset="0.0" />
                    <GradientStop Color="{StaticResource Primary}" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
            <VerticalStackLayout Padding="20,44,20,16" Spacing="2">
                <Label Text="🌱"
                       FontSize="24"
                       HorizontalOptions="Center" />
                <Label Text="FloraScan"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center" />
                <Label x:Name="BienvenidoLabel"
                       Text="Bienvenido"
                       FontSize="14"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource PrimaryLight}" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" Padding="24,28,24,24">
                <Label Text="Presiona el botón para comenzar a identificar plantas"
                       FontSize="16"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource Gray500}" />

                <Button x:Name="IdentificarBtn" Text="📷  Identificar Planta"
                        Clicked="OnIdentificarPlanta"
                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                        FontSize="18" FontAttributes="Bold"
                        CornerRadius="16"
                        Padding="20,16"
                        HeightRequest="56"
                        HorizontalOptions="Fill" />

                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False" IsVisible="False"
                                   Color="{StaticResource Primary}"
                                   HeightRequest="40"
                                   VerticalOptions="Center" />

                <Border x:Name="ResultadoFrame"
                        IsVisible="False"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 16"
                        Stroke="{StaticResource PrimaryLight}"
                        StrokeThickness="1"
                        Padding="20"
                        HorizontalOptions="Fill">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.1" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="🌿"
                               FontSize="32"
                               HorizontalOptions="Center" />
                        <BoxView HeightRequest="2"
                                 Color="{StaticResource PrimaryLight}"
                                 Margin="30,4"
                                 HorizontalOptions="Fill" />
                        <Label x:Name="ResultadoNombreCientifico"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                        <Label x:Name="ResultadoNombreComun"
                               FontSize="14"
                               TextColor="{StaticResource Tertiary}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                        <Label x:Name="ResultadoScore"
                               FontSize="13"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="Cerrar sesión"
                        Clicked="OnCerrarSesion"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"
                        BorderColor="{StaticResource Primary}"
                        BorderWidth="1.5"
                        CornerRadius="14"
                        Padding="20,14"
                        HeightRequest="48"
                        HorizontalOptions="Fill"
                        Margin="0,8,0,0" />

                <Label Text="Sobre nosotros"
                       FontSize="14"
                       TextColor="{StaticResource Secondary}"
                       HorizontalOptions="Center"
                       TextDecorations="Underline">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSobreNosotros" />
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>
        </ScrollView>

        <Border x:Name="SuccessOverlay"
                Grid.RowSpan="2"
                IsVisible="False"
                BackgroundColor="#80000000"
                VerticalOptions="Fill" HorizontalOptions="Fill">
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="32"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="300">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.2" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Label Text="🌿"
                           FontSize="48"
                           HorizontalOptions="Center" />
                    <Label Text="¡Planta identificada!"
                           FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                    <BoxView HeightRequest="2"
                             Color="{StaticResource PrimaryLight}"
                             Margin="20,0"
                             HorizontalOptions="Fill" />
                    <Button Text="OK"
                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                            CornerRadius="14" Padding="20,12"
                            FontSize="16" FontAttributes="Bold"
                            HorizontalOptions="Fill"
                            HeightRequest="48"
                            Clicked="OnCerrarSuccess" />
                </VerticalStackLayout>
            </Border>
        </Border>
    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Identificador.Views.SobreNosotros"
             Title="Sobre nosotros"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.RowSpan="3">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1B5E20" Offset="0.0" />
                    <GradientStop Color="#2E7D32" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>

        <BoxView HeightRequest="5"
                 Color="{StaticResource PrimaryLight}"
                 HorizontalOptions="Fill" />

        <Border Grid.Row="1"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 20"
                Stroke="Transparent"
                Padding="28"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Margin="30,20">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,6" Radius="16" Opacity="0.15" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                <Label Text="🌿"
                       FontSize="42"
                       HorizontalOptions="Center" />
                <Label Text="Sobre nosotros"
                       FontSize="24" FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center" />
                <BoxView HeightRequest="1"
                         Color="{StaticResource PrimaryLight}"
                         Margin="20,4"
                         HorizontalOptions="Fill" />
                <Label Text="Aplicación desarrollada en la asignatura de Programación .NET como proyecto final. 
                       Es un identificador de plantas que funciona al tomar fotos con la cámara, o al subir una foto desde el dispositivo."
                       FontSize="15"
                       TextColor="{StaticResource Tertiary}"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap" />
                <Button Text="Volver atrás"
                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                        CornerRadius="12"
                        FontSize="15" FontAttributes="Bold"
                        Padding="16,12"
                        HeightRequest="48"
                        HorizontalOptions="Fill"
                        Clicked="OnVolver" />
            </VerticalStackLayout>
        </Border>

        <BoxView Grid.Row="2"
                 HeightRequest="6"
                 Color="{StaticResource PrimaryLight}"
                 HorizontalOptions="Fill" />
    </Grid>
</ContentPage>
